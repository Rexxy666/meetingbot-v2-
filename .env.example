# 前端 API / Socket 位址（正式環境請指到 Render 後端）
# VITE_API_URL=https://your-backend.onrender.com

# ── Firebase 前端（Hosting + Google Auth）──────────────────────────────
# Console → 專案設定 → 您的應用程式 → SDK 設定
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase 後端 Admin（Render 環境變數）──────────────────────────────
# 優先用 Firestore；未設定時才退回 MONGODB_URI / 本機 JSON
FIREBASE_PROJECT_ID=
# 服務帳戶 JSON 整段字串（Render 建議貼在這裡；勿提交 git）
FIREBASE_SERVICE_ACCOUNT_JSON=

# 可選：仍可用 MongoDB（未設 Firebase Admin 時）
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/meetflow?retryWrites=true&w=majority

# JWT 簽章密鑰（正式環境務必改成隨機長字串）
JWT_SECRET=please-change-this-in-production

# Google Gemini API Key（僅後端使用，勿放前端 / 勿提交 git）
GEMINI_API_KEY=

# 可選：模型名稱
# GEMINI_MODEL=gemini-3.5-flash

# 可選：額外允許的前端來源（Firebase Hosting 網域請加進來）
# CLIENT_ORIGIN=https://your-app.web.app,https://your-app.firebaseapp.com

# 設為 false 可改回嚴格 CORS 白名單
# CORS_ALLOW_ALL=true
