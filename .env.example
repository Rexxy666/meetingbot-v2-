# 前端 API / Socket 位址（手機同網段請用電腦 LAN IP）
# VITE_API_URL=http://192.168.50.51:3001

# 後端：MongoDB Atlas 連線字串（Render 必填，否則重啟會丟資料）
# 範例：mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/meetflow?retryWrites=true&w=majority
MONGODB_URI=

# JWT 簽章密鑰（正式環境務必改成隨機長字串）
JWT_SECRET=please-change-this-in-production

# Google Gemini API Key（僅後端使用，勿放前端 / 勿提交 git）
GEMINI_API_KEY=

# 可選：模型名稱（預設 gemini-3.5-flash；2.5 已對新帳號不可用）
# GEMINI_MODEL=gemini-3.5-flash

# 可選：額外允許的前端來源（逗號分隔）
# CLIENT_ORIGIN=http://192.168.50.51:5174

# 設為 false 可改回嚴格 CORS 白名單
# CORS_ALLOW_ALL=true
